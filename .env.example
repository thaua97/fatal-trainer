# Base URL da API REST (backend em backend/)
# Em dev: subir PostgreSQL + API antes do front (docker compose up -d && npm run dev)
NUXT_PUBLIC_API_BASE_URL=http://localhost:3333/api
# Dev only: true = usa Nitro mock (/api) em vez da API externa
NUXT_PUBLIC_USE_MOCK_API=false

# Opcional: origem para paths /uploads/* (padrão = host da API sem /api)
# NUXT_PUBLIC_ASSETS_BASE_URL=http://localhost:3333
